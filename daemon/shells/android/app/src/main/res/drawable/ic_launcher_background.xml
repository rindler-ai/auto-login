<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- "Tap Ripple" icon: a near-black field so the off-white tap-to-unlock mark
         reads premium and minimal, and stands apart from the sea of colored
         shield/lock apps. -->
    <path android:pathData="M0,0 h108 v108 h-108 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="0" android:endY="108"
                android:startColor="#16171D"
                android:endColor="#0A0B0E" />
        </aapt:attr>
    </path>
</vector>
