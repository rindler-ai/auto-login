<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- "Tap Ripple": a fingertip point radiating two concentric ripples — one tap
         and you're in. Off-white on near-black; the whole mark sits inside the 66%
         adaptive safe zone (outer ripple reaches ~31.5 units from center). -->
    <!-- outer ripple (faintest) -->
    <path
        android:pathData="M54,25 A29,29 0 1,1 54,83 A29,29 0 1,1 54,25"
        android:strokeColor="#F5F5F7"
        android:strokeWidth="5"
        android:strokeAlpha="0.42" />
    <!-- inner ripple -->
    <path
        android:pathData="M54,34 A20,20 0 1,1 54,74 A20,20 0 1,1 54,34"
        android:strokeColor="#F5F5F7"
        android:strokeWidth="6"
        android:strokeAlpha="0.85" />
    <!-- fingertip point -->
    <path
        android:pathData="M54,43 A11,11 0 1,1 54,65 A11,11 0 1,1 54,43 Z"
        android:fillColor="#F5F5F7" />
</vector>
