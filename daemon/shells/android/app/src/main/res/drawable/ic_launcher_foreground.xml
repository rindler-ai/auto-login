<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">
    <!-- "Check-Key": a key whose shaft bends into a checkmark — key (your credential)
         + check (signed in, automatically), one gesture. Mint-to-white stroke.
         All ink sits in the 66% adaptive safe zone. (#3958) -->
    <group android:translateX="2" android:translateY="14">
        <!-- shaft + checkmark -->
        <path
            android:pathData="M148,268 L198,318 L293,225"
            android:strokeWidth="40"
            android:strokeLineCap="round"
            android:strokeLineJoin="round">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear"
                    android:startX="150" android:startY="310"
                    android:endX="360" android:endY="150"
                    android:startColor="#FFFFFF" android:endColor="#5EEAD4" />
            </aapt:attr>
        </path>
        <!-- two key teeth -->
        <path
            android:pathData="M238,279 L262,303"
            android:strokeWidth="26"
            android:strokeLineCap="round">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear"
                    android:startX="150" android:startY="310"
                    android:endX="360" android:endY="150"
                    android:startColor="#FFFFFF" android:endColor="#5EEAD4" />
            </aapt:attr>
        </path>
        <path
            android:pathData="M264,253 L288,277"
            android:strokeWidth="26"
            android:strokeLineCap="round">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear"
                    android:startX="150" android:startY="310"
                    android:endX="360" android:endY="150"
                    android:startColor="#FFFFFF" android:endColor="#5EEAD4" />
            </aapt:attr>
        </path>
        <!-- bow ring -->
        <path
            android:pathData="M298,186 a34,34 0 1,0 68,0 a34,34 0 1,0 -68,0 Z"
            android:strokeWidth="26">
            <aapt:attr name="android:strokeColor">
                <gradient android:type="linear"
                    android:startX="150" android:startY="310"
                    android:endX="360" android:endY="150"
                    android:startColor="#FFFFFF" android:endColor="#5EEAD4" />
            </aapt:attr>
        </path>
    </group>
</vector>
